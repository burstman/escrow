# Server
PORT=8080
SESSION_SECRET=change-this-to-a-random-64-char-secret
DEV_MODE=true

# Postgres
DATABASE_URL=postgres://escrow:escrow@localhost:5432/escrow?sslmode=disable

# Fabric (ignored when DEV_MODE=true)
FABRIC_GATEWAY_ENDPOINT=localhost:7051
FABRIC_CERT_PATH=./fabric/crypto/appUser-cert.pem
FABRIC_KEY_PATH=./fabric/crypto/appUser-key.pem
FABRIC_TLS_CERT_PATH=./fabric/crypto/peer-tls.pem
FABRIC_CHANNEL=escrow-channel
FABRIC_CHAINCODE=escrow
FABRIC_MSP_ID=PlatformMSP

# Storage
UPLOAD_DIR=./uploads

# Manual payment info shown to clients
BUSINESS_BANK_NAME=Banque Nationale Agricole
BUSINESS_RIB=00000000000000000000
BUSINESS_ACCOUNT_NAME=Escrow.tn SARL
